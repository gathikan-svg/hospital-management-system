<Window x:Class="IntHospitalsys.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hospital Management System - Role Login" Height="600" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F0F4F8">
        <Border Background="White" CornerRadius="10" Margin="30" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="0" Opacity="0.1" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Hospital Management" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <TextBlock Text="Role-Based Access" FontSize="13" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,5,0,25"/>

                <TextBlock Text="Username" Margin="0,10,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                <TextBox x:Name="TxtUsername" Height="35" Padding="5" VerticalContentAlignment="Center"/>

                <TextBlock Text="Password" Margin="0,15,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                <PasswordBox x:Name="TxtPassword" Height="35" Padding="5" VerticalContentAlignment="Center"/>

                <Button x:Name="BtnDoctorLogin" Content="Doctor Login" Height="40" Margin="0,25,0,0" 
                        Background="#2980B9" Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnDoctorLogin_Click"/>

                <Button x:Name="BtnStaffLogin" Content="Staff Login" Height="40" Margin="0,10,0,0" 
                        Background="#16A085" Foreground="White" FontWeight="Bold" Cursor="Hand"
                        Click="BtnStaffLogin_Click"/>

                <Separator Margin="0,25,0,10" Background="#D5DBDB"/>
                <TextBlock Text="Are you a patient?" HorizontalAlignment="Center" Foreground="#7F8C8D"/>
                <Button x:Name="BtnPatientJump" Content="Register for Appointment" 
                        Background="Transparent" BorderThickness="0" Foreground="#2980B9" 
                        FontWeight="SemiBold" Cursor="Hand" Margin="0,5,0,0"
                        Click="BtnPatientJump_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>