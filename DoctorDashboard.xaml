<Window x:Class="IntHospitalsys.DoctorDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Doctor Dashboard" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F4F7F6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Width="50" Height="50" Background="#2980B9" CornerRadius="25">
                <TextBlock Text="Dr" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                <TextBlock x:Name="LblWelcome" Text="Welcome, Dr. [Name]" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Hospital Management System | Clinical View" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,40,0">
                    <TextBlock Text="Total Patients Assigned" FontSize="14" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="TxtTotalPatients" Text="0" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                </StackPanel>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,40,0"/>
                <StackPanel VerticalAlignment="Center">
                    <Button x:Name="BtnRefresh" Content="Refresh List" Width="100" Height="30" Background="#34495E" Foreground="White" Click="BtnRefresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="2" Header="Registered Patient Appointments" FontSize="14" FontWeight="SemiBold">
            <DataGrid x:Name="DgPatients" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="True" Margin="10" Background="White" RowBackground="GhostWhite" AlternatingRowBackground="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Patient ID" Binding="{Binding PatientId}" Width="80"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactNumber}" Width="120"/>
                    <DataGridTextColumn Header="Appt Date" Binding="{Binding AppDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                    <DataGridTextColumn Header="Time Slot" Binding="{Binding TimeSlot}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>